    if idx == 57: return 92
    if idx == 58: return 95
    if idx == 59: return 98
    if idx == 60: return 112
    if idx == 61: return 100
    if idx == 62: return 103
    return 99

fun jpeg_chroma_base(idx: i32) -> i32:
    if idx == 0: return 17
    if idx == 1: return 18
    if idx == 2: return 24
    if idx == 3: return 47
    if idx == 4: return 99
    if idx == 5: return 99
    if idx == 6: return 99
    if idx == 7: return 99
    if idx == 8: return 18
    if idx == 9: return 21
    if idx == 10: return 26
    if idx == 11: return 66
    if idx == 12: return 99
    if idx == 13: return 99
    if idx == 14: return 99
    if idx == 15: return 99
    if idx == 16: return 24
    if idx == 17: return 26
    if idx == 18: return 56
    if idx == 19: return 99
    if idx == 20: return 99
    if idx == 21: return 99
    if idx == 22: return 99
    if idx == 23: return 99
    if idx == 24: return 47
    if idx == 25: return 66
    return 99

fun jpeg_quant_value(table_id: i32, idx: i32, quality: i32) -> i32:
    q: i32 = jpeg_clamp_quality(quality)
    scale: i32 = 0
    if q < 50:
        scale = 5000 / q
    else:
        scale = 200 - (q * 2)

    base: i32 = jpeg_luma_base(idx)
    if table_id == 1:
        base = jpeg_chroma_base(idx)

    value: i32 = (base * scale + 50) / 100
    return jpeg_clamp_i32(value, 1, 255)

fun jpeg_rgb_component(color: ImageColor, comp: i32) -> i32:
    r: i32 = image_red(color)
    g: i32 = image_green(color)
    b: i32 = image_blue(color)
    if comp == 0:
        return ((77 * r) + (150 * g) + (29 * b)) >> 8
    if comp == 1:
        return (((0 - 43) * r) + ((0 - 85) * g) + (128 * b) + 32768) >> 8
    return ((128 * r) + ((0 - 107) * g) + ((0 - 21) * b) + 32768) >> 8

fun jpeg_pixel_component(img: Image, px: i32, py: i32, comp: i32) -> i32:
    x: i32 = px
    y: i32 = py
    if x >= img.width:
        x = img.width - 1
    if y >= img.height:
        y = img.height - 1
    color: ImageColor = img.get_pixel(x, y)
    return jpeg_rgb_component(color, comp) - 128

fun jpeg_compute_coeff(img: Image, block_x: i32, block_y: i32, comp: i32, u: i32, v: i32, quality: i32) -> i32:
    sum: i64 = 0
    y: i32 = 0
    while y < 8:
        x: i32 = 0
        while x < 8:
            sample: i32 = jpeg_pixel_component(img, block_x + x, block_y + y, comp)
            bx: i32 = jpeg_dct_basis(u, x)
            by: i32 = jpeg_dct_basis(v, y)
            sum = sum + ((sample as i64) * (bx as i64) * (by as i64))
            x = x + 1
        y = y + 1

    natural_idx: i32 = (v * 8) + u
    qtable: i32 = 0
    if comp != 0:
        qtable = 1
    quant: i32 = jpeg_quant_value(qtable, natural_idx, quality)
    coeff: i32 = jpeg_div_round(sum, 4194304 * (quant as i64))
    if natural_idx == 0:
        return coeff
    return jpeg_clamp_i32(coeff, 0 - JPEG_MAX_AC_VALUE, JPEG_MAX_AC_VALUE)

fun jpeg_fill_block(img: Image, coeffs: i64, block_x: i32, block_y: i32, comp: i32, quality: i32):
    v: i32 = 0
    while v < 8:
        u: i32 = 0
        while u < 8:
            idx: i32 = (v * 8) + u
            coeff: i32 = jpeg_compute_coeff(img, block_x, block_y, comp, u, v, quality)
            Memory.write_i32(coeffs + ((idx as i64) * 4), coeff)
            u = u + 1
        v = v + 1

fun jpeg_get_coeff(coeffs: i64, natural_idx: i32) -> i32:
    return Memory.read_i32(coeffs + ((natural_idx as i64) * 4))

fun jpeg_encode_dc(bw: JpegBitWriter, value: i32):
    diff: i32 = jpeg_clamp_i32(value, 0 - JPEG_MAX_DC_DIFF, JPEG_MAX_DC_DIFF)
    size: i32 = jpeg_category(diff)
    bw.write_bits(size, 4)
    if size > 0:
        bw.write_bits(jpeg_amplitude_bits(diff, size), size)

fun jpeg_encode_ac_symbol(bw: JpegBitWriter, symbol: i32):
    code: i32 = 0
    if symbol == 0:
        code = 0
    elif symbol == 240:
        code = 1
    else:
        run: i32 = (symbol >> 4) & 15
        size: i32 = symbol & 15
        code = 2 + (run * 10) + (size - 1)
    bw.write_bits(code, 8)

fun jpeg_encode_block(bw: JpegBitWriter, coeffs: i64, prev_dc: i32) -> i32:
    dc: i32 = jpeg_get_coeff(coeffs, 0)
    jpeg_encode_dc(bw, dc - prev_dc)

    zero_run: i32 = 0
    zi: i32 = 1
    while zi < 64:
        coeff: i32 = jpeg_get_coeff(coeffs, jpeg_zigzag(zi))
        if coeff == 0:
            zero_run = zero_run + 1
        else:
            while zero_run > 15:
                jpeg_encode_ac_symbol(bw, 240)
                zero_run = zero_run - 16

            size: i32 = jpeg_category(coeff)
            if size > 10:
                size = 10
                coeff = jpeg_clamp_i32(coeff, 0 - JPEG_MAX_AC_VALUE, JPEG_MAX_AC_VALUE)
            symbol: i32 = (zero_run << 4) | size
            jpeg_encode_ac_symbol(bw, symbol)
            bw.write_bits(jpeg_amplitude_bits(coeff, size), size)
            zero_run = 0
        zi = zi + 1

    if zero_run > 0:
        jpeg_encode_ac_symbol(bw, 0)

    return dc

fun jpeg_write_app0(file: File) -> i32:
    seg: i64 = Memory.malloc_zeroed(18)
    pos: i64 = 0
    pos = jpeg_write_u8(seg, pos, 255)
    pos = jpeg_write_u8(seg, pos, 224)
    pos = jpeg_write_be16(seg, pos, 16)
    pos = jpeg_write_u8(seg, pos, 74)
    pos = jpeg_write_u8(seg, pos, 70)
    pos = jpeg_write_u8(seg, pos, 73)
    pos = jpeg_write_u8(seg, pos, 70)
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_u8(seg, pos, 1)
    pos = jpeg_write_u8(seg, pos, 1)
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_be16(seg, pos, 1)
    pos = jpeg_write_be16(seg, pos, 1)
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_u8(seg, pos, 0)
    written: i32 = file.write_bytes(seg, 18)
    Memory.free(seg)
    if written == 18:
        return 1
    return 0

fun jpeg_write_dqt(file: File, table_id: i32, quality: i32) -> i32:
    seg: i64 = Memory.malloc_zeroed(69)
    pos: i64 = 0
    pos = jpeg_write_u8(seg, pos, 255)
    pos = jpeg_write_u8(seg, pos, 219)
    pos = jpeg_write_be16(seg, pos, 67)
    pos = jpeg_write_u8(seg, pos, table_id)
    i: i32 = 0
    while i < 64:
        idx: i32 = jpeg_zigzag(i)
        pos = jpeg_write_u8(seg, pos, jpeg_quant_value(table_id, idx, quality))
        i = i + 1
    written: i32 = file.write_bytes(seg, 69)
    Memory.free(seg)
    if written == 69:
        return 1
    return 0

fun jpeg_write_sof0(file: File, width: i32, height: i32) -> i32:
    seg: i64 = Memory.malloc_zeroed(19)
    pos: i64 = 0
    pos = jpeg_write_u8(seg, pos, 255)
    pos = jpeg_write_u8(seg, pos, 192)
    pos = jpeg_write_be16(seg, pos, 17)
    pos = jpeg_write_u8(seg, pos, 8)
    pos = jpeg_write_be16(seg, pos, height)
    pos = jpeg_write_be16(seg, pos, width)
    pos = jpeg_write_u8(seg, pos, 3)
    pos = jpeg_write_u8(seg, pos, 1)
    pos = jpeg_write_u8(seg, pos, 17)
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_u8(seg, pos, 2)
    pos = jpeg_write_u8(seg, pos, 17)
    pos = jpeg_write_u8(seg, pos, 1)
    pos = jpeg_write_u8(seg, pos, 3)
    pos = jpeg_write_u8(seg, pos, 17)
    pos = jpeg_write_u8(seg, pos, 1)
    written: i32 = file.write_bytes(seg, 19)
    Memory.free(seg)
    if written == 19:
        return 1
    return 0

fun jpeg_write_dht_dc(file: File, table_id: i32) -> i32:
    seg: i64 = Memory.malloc_zeroed(33)
    pos: i64 = 0
    pos = jpeg_write_u8(seg, pos, 255)
    pos = jpeg_write_u8(seg, pos, 196)
    pos = jpeg_write_be16(seg, pos, 31)
    pos = jpeg_write_u8(seg, pos, table_id)
    i: i32 = 1
    while i <= 16:
        count: i32 = 0
        if i == 4:
            count = 12
        pos = jpeg_write_u8(seg, pos, count)
        i = i + 1
    v: i32 = 0
    while v < 12:
        pos = jpeg_write_u8(seg, pos, v)
        v = v + 1
    written: i32 = file.write_bytes(seg, 33)
    Memory.free(seg)
    if written == 33:
        return 1
    return 0

fun jpeg_write_dht_ac(file: File, table_id: i32) -> i32:
    seg_len: i32 = 183
    seg: i64 = Memory.malloc_zeroed(seg_len as i64)
    pos: i64 = 0
    pos = jpeg_write_u8(seg, pos, 255)
    pos = jpeg_write_u8(seg, pos, 196)
    pos = jpeg_write_be16(seg, pos, 181)
    pos = jpeg_write_u8(seg, pos, 16 | table_id)
    i: i32 = 1
    while i <= 16:
        count: i32 = 0
        if i == 8:
            count = 162
        pos = jpeg_write_u8(seg, pos, count)
        i = i + 1
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_u8(seg, pos, 240)
    run: i32 = 0
    while run < 16:
        size: i32 = 1
        while size <= 10:
            pos = jpeg_write_u8(seg, pos, (run << 4) | size)
            size = size + 1
        run = run + 1
    written: i32 = file.write_bytes(seg, seg_len)
    Memory.free(seg)
    if written == seg_len:
        return 1
    return 0

fun jpeg_write_sos(file: File) -> i32:
    seg: i64 = Memory.malloc_zeroed(14)
    pos: i64 = 0
    pos = jpeg_write_u8(seg, pos, 255)
    pos = jpeg_write_u8(seg, pos, 218)
    pos = jpeg_write_be16(seg, pos, 12)
    pos = jpeg_write_u8(seg, pos, 3)
    pos = jpeg_write_u8(seg, pos, 1)
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_u8(seg, pos, 2)
    pos = jpeg_write_u8(seg, pos, 17)
    pos = jpeg_write_u8(seg, pos, 3)
    pos = jpeg_write_u8(seg, pos, 17)
    pos = jpeg_write_u8(seg, pos, 0)
    pos = jpeg_write_u8(seg, pos, 63)
    pos = jpeg_write_u8(seg, pos, 0)
    written: i32 = file.write_bytes(seg, 14)
    Memory.free(seg)
    if written == 14:
        return 1
    return 0

fun jpeg_write_headers(file: File, width: i32, height: i32, quality: i32) -> i32:
    ok: i32 = 1
    if jpeg_write_marker(file, 216) == 0: ok = 0
    if jpeg_write_app0(file) == 0: ok = 0
    if jpeg_write_dqt(file, 0, quality) == 0: ok = 0
    if jpeg_write_dqt(file, 1, quality) == 0: ok = 0
    if jpeg_write_sof0(file, width, height) == 0: ok = 0
    if jpeg_write_dht_dc(file, 0) == 0: ok = 0
    if jpeg_write_dht_ac(file, 0) == 0: ok = 0
    if jpeg_write_dht_dc(file, 1) == 0: ok = 0
    if jpeg_write_dht_ac(file, 1) == 0: ok = 0
    if jpeg_write_sos(file) == 0: ok = 0
    return ok

fun jpeg_encode_entropy(img: Image, bw: JpegBitWriter, quality: i32):
    coeffs: i64 = Memory.malloc_zeroed(64 * 4)
    prev_y: i32 = 0
    prev_cb: i32 = 0
    prev_cr: i32 = 0
    by: i32 = 0
    while by < img.height:
        bx: i32 = 0
        while bx < img.width:
            jpeg_fill_block(img, coeffs, bx, by, 0, quality)
            prev_y = jpeg_encode_block(bw, coeffs, prev_y)

            jpeg_fill_block(img, coeffs, bx, by, 1, quality)
            prev_cb = jpeg_encode_block(bw, coeffs, prev_cb)

            jpeg_fill_block(img, coeffs, bx, by, 2, quality)
            prev_cr = jpeg_encode_block(bw, coeffs, prev_cr)

            bx = bx + 8
        by = by + 8
    bw.flush()
    Memory.free(coeffs)

struct JPEG:
    static fun save(img: Image, path: str, quality: i32) -> i32:
        if img.is_valid() == 0:
            return 0

        q: i32 = jpeg_clamp_quality(quality)
        file: File = File.open_cwd(path, "w")
        if file.is_valid() == false:
            return 0

        ok: i32 = jpeg_write_headers(file, img.width, img.height, q)

        entropy_cap: i64 = ((img.width as i64) * (img.height as i64) * 10) + 8192
        bw: JpegBitWriter = JpegBitWriter.create(entropy_cap)
        jpeg_encode_entropy(img, bw, q)
        written: i32 = file.write_bytes(bw.data, bw.pos as i32)
        if written != (bw.pos as i32):
            ok = 0
        bw.free()

        if jpeg_write_marker(file, 217) == 0:
            ok = 0
        file.close()
        return ok

    static fun load(path: str) -> Image:
        # TODO: JPEG decoding is much larger than writing; add after encoder settles.
        return Image.empty()


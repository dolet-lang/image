# ============================
#  JPEG Codec
# ============================
# Minimal baseline JPEG writer for experiments.
# Writes RGB baseline JPEG, 8-bit, no chroma subsampling, pure Dolet.

JPEG_MAX_AC_VALUE: i32 = 1023
JPEG_MAX_DC_DIFF: i32 = 2047

struct JpegBitWriter:
    data: i64 = 0
    capacity: i64 = 0
    pos: i64 = 0
    current: i32 = 0
    bit_count: i32 = 0

    static fun create(capacity: i64) -> JpegBitWriter:
        buf: i64 = Memory.malloc_zeroed(capacity)
        return JpegBitWriter(data=buf, capacity=capacity, pos=0, current=0, bit_count=0)

    fun free(self):
        if self.data != 0:
            Memory.free(self.data)
        self.data = 0
        self.capacity = 0
        self.pos = 0
        self.current = 0
        self.bit_count = 0

    fun write_byte(self, value: i32):
        if self.pos >= self.capacity:
            return
        v: i32 = value & 255
        Memory.write_i8(self.data + self.pos, v as i8)
        self.pos = self.pos + 1
        if v == 255:
            if self.pos < self.capacity:
                Memory.write_i8(self.data + self.pos, 0 as i8)
                self.pos = self.pos + 1

    fun write_bits(self, code: i32, size: i32):
        if size <= 0:
            return
        i: i32 = size - 1
        while i >= 0:
            bit: i32 = (code >> i) & 1
            self.current = (self.current << 1) | bit
            self.bit_count = self.bit_count + 1
            if self.bit_count == 8:
                self.write_byte(self.current)
                self.current = 0
                self.bit_count = 0
            i = i - 1

    fun flush(self):
        if self.bit_count > 0:
            pad: i32 = 8 - self.bit_count
            self.current = (self.current << pad) | ((1 << pad) - 1)
            self.write_byte(self.current)
            self.current = 0
            self.bit_count = 0

fun jpeg_write_u8(buf: i64, pos: i64, value: i32) -> i64:
    Memory.write_i8(buf + pos, value as i8)
    return pos + 1

fun jpeg_write_be16(buf: i64, pos: i64, value: i32) -> i64:
    Memory.write_i8(buf + pos, ((value >> 8) & 255) as i8)
    Memory.write_i8(buf + pos + 1, (value & 255) as i8)
    return pos + 2

fun jpeg_write_marker(file: File, marker: i32) -> i32:
    buf: i64 = Memory.malloc_zeroed(2)
    Memory.write_i8(buf, 255 as i8)
    Memory.write_i8(buf + 1, marker as i8)
    written: i32 = file.write_bytes(buf, 2)
    Memory.free(buf)
    if written == 2:
        return 1
    return 0

fun jpeg_clamp_quality(quality: i32) -> i32:
    if quality < 1:
        return 1
    if quality > 100:
        return 100
    return quality

fun jpeg_abs(value: i32) -> i32:
    if value < 0:
        return 0 - value
    return value

fun jpeg_div_round(value: i64, divisor: i64) -> i32:
    if value >= 0:
        return ((value + (divisor / 2)) / divisor) as i32
    return ((value - (divisor / 2)) / divisor) as i32

fun jpeg_clamp_i32(value: i32, min_value: i32, max_value: i32) -> i32:
    if value < min_value:
        return min_value
    if value > max_value:
        return max_value
    return value

fun jpeg_category(value: i32) -> i32:
    v: i32 = jpeg_abs(value)
    if v == 0:
        return 0
    size: i32 = 0
    while v > 0:
        size = size + 1
        v = v >> 1
    return size

fun jpeg_amplitude_bits(value: i32, size: i32) -> i32:
    if size == 0:
        return 0
    if value >= 0:
        return value
    return ((1 << size) - 1) + value

fun jpeg_zigzag(idx: i32) -> i32:
    if idx == 0: return 0
    if idx == 1: return 1
    if idx == 2: return 8
    if idx == 3: return 16
    if idx == 4: return 9
    if idx == 5: return 2
    if idx == 6: return 3
    if idx == 7: return 10
    if idx == 8: return 17
    if idx == 9: return 24
    if idx == 10: return 32
    if idx == 11: return 25
    if idx == 12: return 18
    if idx == 13: return 11
    if idx == 14: return 4
    if idx == 15: return 5
    if idx == 16: return 12
    if idx == 17: return 19
    if idx == 18: return 26
    if idx == 19: return 33
    if idx == 20: return 40
    if idx == 21: return 48
    if idx == 22: return 41
    if idx == 23: return 34
    if idx == 24: return 27
    if idx == 25: return 20
    if idx == 26: return 13
    if idx == 27: return 6
    if idx == 28: return 7
    if idx == 29: return 14
    if idx == 30: return 21
    if idx == 31: return 28
    if idx == 32: return 35
    if idx == 33: return 42
    if idx == 34: return 49
    if idx == 35: return 56
    if idx == 36: return 57
    if idx == 37: return 50
    if idx == 38: return 43
    if idx == 39: return 36
    if idx == 40: return 29
    if idx == 41: return 22
    if idx == 42: return 15
    if idx == 43: return 23
    if idx == 44: return 30
    if idx == 45: return 37
    if idx == 46: return 44
    if idx == 47: return 51
    if idx == 48: return 58
    if idx == 49: return 59
    if idx == 50: return 52
    if idx == 51: return 45
    if idx == 52: return 38
    if idx == 53: return 31
    if idx == 54: return 39
    if idx == 55: return 46
    if idx == 56: return 53
    if idx == 57: return 60
    if idx == 58: return 61
    if idx == 59: return 54
    if idx == 60: return 47
    if idx == 61: return 55
    if idx == 62: return 62
    return 63

fun jpeg_dct_basis(u: i32, x: i32) -> i32:
    if u == 0:
        return 724
    if u == 1:
        if x == 0: return 1004
        if x == 1: return 851
        if x == 2: return 569
        if x == 3: return 200
        if x == 4: return -200
        if x == 5: return -569
        if x == 6: return -851
        return -1004
    if u == 2:
        if x == 0: return 946
        if x == 1: return 392
        if x == 2: return -392
        if x == 3: return -946
        if x == 4: return -946
        if x == 5: return -392
        if x == 6: return 392
        return 946
    if u == 3:
        if x == 0: return 851
        if x == 1: return -200
        if x == 2: return -1004
        if x == 3: return -569
        if x == 4: return 569
        if x == 5: return 1004
        if x == 6: return 200
        return -851
    if u == 4:
        if x == 0: return 724
        if x == 1: return -724
        if x == 2: return -724
        if x == 3: return 724
        if x == 4: return 724
        if x == 5: return -724
        if x == 6: return -724
        return 724
    if u == 5:
        if x == 0: return 569
        if x == 1: return -1004
        if x == 2: return 200
        if x == 3: return 851
        if x == 4: return -851
        if x == 5: return -200
        if x == 6: return 1004
        return -569
    if u == 6:
        if x == 0: return 392
        if x == 1: return -946
        if x == 2: return 946
        if x == 3: return -392
        if x == 4: return -392
        if x == 5: return 946
        if x == 6: return -946
        return 392
    if x == 0: return 200
    if x == 1: return -569
    if x == 2: return 851
    if x == 3: return -1004
    if x == 4: return 1004
    if x == 5: return -851
    if x == 6: return 569
    return -200

fun jpeg_luma_base(idx: i32) -> i32:
    if idx == 0: return 16
    if idx == 1: return 11
    if idx == 2: return 10
    if idx == 3: return 16
    if idx == 4: return 24
    if idx == 5: return 40
    if idx == 6: return 51
    if idx == 7: return 61
    if idx == 8: return 12
    if idx == 9: return 12
    if idx == 10: return 14
    if idx == 11: return 19
    if idx == 12: return 26
    if idx == 13: return 58
    if idx == 14: return 60
    if idx == 15: return 55
    if idx == 16: return 14
    if idx == 17: return 13
    if idx == 18: return 16
    if idx == 19: return 24
    if idx == 20: return 40
    if idx == 21: return 57
    if idx == 22: return 69
    if idx == 23: return 56
    if idx == 24: return 14
    if idx == 25: return 17
    if idx == 26: return 22
    if idx == 27: return 29
    if idx == 28: return 51
    if idx == 29: return 87
    if idx == 30: return 80
    if idx == 31: return 62
    if idx == 32: return 18
    if idx == 33: return 22
    if idx == 34: return 37
    if idx == 35: return 56
    if idx == 36: return 68
    if idx == 37: return 109
    if idx == 38: return 103
    if idx == 39: return 77
    if idx == 40: return 24
    if idx == 41: return 35
    if idx == 42: return 55
    if idx == 43: return 64
